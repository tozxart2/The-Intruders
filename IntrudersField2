local _activeInfoButton = nil                 -- Track which info button is currently showing tooltip

local function HideInfoTooltip()
    if InfoTooltip.Visible then
        TweenService:Create(InfoTooltip, TweenInfo.new(0.15, Enum.EasingStyle.Quint), { BackgroundTransparency = 1 })
            :Play()
        TweenService:Create(TooltipText, TweenInfo.new(0.15, Enum.EasingStyle.Quint), { TextTransparency = 1 }):Play()
        TweenService:Create(TooltipStroke, TweenInfo.new(0.15, Enum.EasingStyle.Quint), { Transparency = 1 }):Play()
        TweenService:Create(TooltipArrow, TweenInfo.new(0.15, Enum.EasingStyle.Quint), { BackgroundTransparency = 1 })
            :Play()
        task.delay(0.15, function()
            if _activeInfoButton == nil then
                InfoTooltip.Visible = false
                TooltipArrow.Visible = false
            end
        end)
    end
    _activeInfoButton = nil
end

local function ShowInfoTooltip(anchorButton, infoText)
    _activeInfoButton = anchorButton
    TooltipText.Text = infoText

    -- Make visible but transparent first for size calculation
    InfoTooltip.BackgroundTransparency = 1
    TooltipText.TextTransparency = 1
    TooltipStroke.Transparency = 1
    TooltipArrow.BackgroundTransparency = 1
    InfoTooltip.Visible = true
    TooltipArrow.Visible = true

    -- Wait a frame for AutomaticSize to calculate
    task.wait()

    -- Position tooltip above the info button, centered horizontally
    local btnPos = anchorButton.AbsolutePosition
    local btnSize = anchorButton.AbsoluteSize
    local tooltipSize = InfoTooltip.AbsoluteSize
    local screenSize = workspace.CurrentCamera.ViewportSize

    -- Default: show above the button
    local tooltipX = btnPos.X + (btnSize.X / 2) - (tooltipSize.X / 2)
    local tooltipY = btnPos.Y - tooltipSize.Y - 8

    -- If tooltip would go above the screen, show below instead
    local showBelow = false
    if tooltipY < 0 then
        tooltipY = btnPos.Y + btnSize.Y + 8
        showBelow = true
    end

    -- Clamp X to stay on screen
    if tooltipX < 4 then tooltipX = 4 end
    if tooltipX + tooltipSize.X > screenSize.X - 4 then
        tooltipX = screenSize.X - tooltipSize.X - 4
    end

    InfoTooltip.Position = UDim2.new(0, tooltipX, 0, tooltipY)

    -- Position arrow
    local arrowX = (btnPos.X + btnSize.X / 2) - tooltipX
    if showBelow then
        TooltipArrow.Position = UDim2.new(0, arrowX, 0, -3)
    else
        TooltipArrow.Position = UDim2.new(0, arrowX, 1, 3)
    end

    -- Tween in
    TweenService:Create(InfoTooltip, TweenInfo.new(0.2, Enum.EasingStyle.Quint), { BackgroundTransparency = 0 }):Play()
    TweenService:Create(TooltipText, TweenInfo.new(0.2, Enum.EasingStyle.Quint), { TextTransparency = 0 }):Play()
    TweenService:Create(TooltipStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quint), { Transparency = 0 }):Play()
    TweenService:Create(TooltipArrow, TweenInfo.new(0.2, Enum.EasingStyle.Quint), { BackgroundTransparency = 0 }):Play()
end

--- Creates a small ℹ icon button next to an element's Title.
--- When hovered or clicked, shows a floating tooltip with the info text.
--- @param parentElement Frame -- The element frame (Button, Toggle, Slider, etc.)
--- @param infoText string -- The info/description text to display
--- @param titleObject TextLabel -- The Title TextLabel to position the icon after
local function CreateInfoButton(parentElement, infoText, titleObject)
    if not infoText or infoText == "" then return end
    if not parentElement then return end

    -- Create the info icon as a circle with "i" inside, positioned inline after title text
    local InfoBtn = Instance.new("TextButton")
    InfoBtn.Name = "InfoButton"
    InfoBtn.Parent = titleObject -- Parent directly to the Title label so position is relative to it
    InfoBtn.Text = ""
    InfoBtn.AutoButtonColor = false
    InfoBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    InfoBtn.BackgroundTransparency = 0.5
    InfoBtn.Size = UDim2.new(0, 14, 0, 14)
    InfoBtn.AnchorPoint = Vector2.new(0, 0.5)
    InfoBtn.ZIndex = 5
    InfoBtn.BorderSizePixel = 0

    -- Position right after rendered text, vertically centered within the title label
    local function updateInfoPosition()
        if titleObject then
            local textWidth = titleObject.TextBounds.X
            InfoBtn.Position = UDim2.new(0, textWidth + 6, 0.5, 0)
        end
    end
    updateInfoPosition()
    if titleObject then
        titleObject:GetPropertyChangedSignal("TextBounds"):Connect(updateInfoPosition)
        titleObject:GetPropertyChangedSignal("Text"):Connect(updateInfoPosition)
    end

    -- Make it a perfect circle
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(1, 0)
    btnCorner.Parent = InfoBtn

    -- Subtle border stroke (faded)
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = Color3.fromRGB(100, 100, 100)
    btnStroke.Thickness = 1
    btnStroke.Transparency = 0.5
    btnStroke.Parent = InfoBtn

    -- "i" letter inside the circle (faded)
    local iLabel = Instance.new("TextLabel")
    iLabel.Name = "Icon"
    iLabel.Parent = InfoBtn
    iLabel.BackgroundTransparency = 1
    iLabel.Size = UDim2.new(1, 0, 1, 0)
    iLabel.Font = Enum.Font.GothamBold
    iLabel.Text = "i"
    iLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
    iLabel.TextTransparency = 0.3
    iLabel.TextSize = 10
    iLabel.ZIndex = 6
    iLabel.TextXAlignment = Enum.TextXAlignment.Center
    iLabel.TextYAlignment = Enum.TextYAlignment.Center

    -- Hover effects
    local hoverActive = false

    InfoBtn.MouseEnter:Connect(function()
        hoverActive = true
        TweenService:Create(InfoBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            BackgroundColor3 = Color3.fromRGB(43, 105, 159),
            BackgroundTransparency = 0
        }):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            Color = Color3.fromRGB(60, 140, 210),
            Transparency = 0
        }):Play()
        TweenService:Create(iLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextTransparency = 0
        }):Play()
        ShowInfoTooltip(InfoBtn, infoText)
    end)

    InfoBtn.MouseLeave:Connect(function()
        hoverActive = false
        TweenService:Create(InfoBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            BackgroundColor3 = Color3.fromRGB(60, 60, 60),
            BackgroundTransparency = 0.5
        }):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            Color = Color3.fromRGB(100, 100, 100),
            Transparency = 0.5
        }):Play()
        TweenService:Create(iLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
            TextColor3 = Color3.fromRGB(140, 140, 140),
            TextTransparency = 0.3
        }):Play()
        task.delay(0.1, function()
            if not hoverActive and _activeInfoButton == InfoBtn then
                HideInfoTooltip()
            end
        end)
    end)

    -- Click/tap support (for mobile)
    InfoBtn.MouseButton1Click:Connect(function()
        if _activeInfoButton == InfoBtn then
            HideInfoTooltip()
        else
            ShowInfoTooltip(InfoBtn, infoText)
            local currentBtn = InfoBtn
            task.delay(4, function()
                if _activeInfoButton == currentBtn then
                    HideInfoTooltip()
                end
            end)
        end
    end)

    return InfoBtn
end

