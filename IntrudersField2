--- Stores per-element pin state:
--- _pinData[element] = {
---     IsPinned = true/false,
---     OriginalParent = <Frame>,
---     OriginalLayoutOrder = <number>,
---     OriginalSize = <UDim2>,
---     Ghost = <Frame or nil>,
---     DragConnection = <RBXScriptConnection or nil>,
---     RenderConnection = <RBXScriptConnection or nil>,
---     PinButton = <ImageButton>,
--- }
local _pinData = {}

--- Make a frame draggable by a drag-point (header area or full frame).
--- Returns a function that disconnects dragging.
local function MakePinDraggable(dragPoint, target)
    local dragging = false
    local didDrag = false -- tracks whether user actually moved the element
    local dragInput, mousePos, framePos
    local connections = {}

    -- Helper: check if a screen position is within the target bounds
    local function isInsideTarget(pos)
        local absPos = target.AbsolutePosition
        local absSize = target.AbsoluteSize
        return pos.X >= absPos.X and pos.X <= absPos.X + absSize.X
            and pos.Y >= absPos.Y and pos.Y <= absPos.Y + absSize.Y
    end

    -- Use global InputBegan so clicks on ANY child element also start the drag
    table.insert(connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if isInsideTarget(input.Position) then
                dragging = true
                didDrag = false
                mousePos = input.Position
                framePos = target.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end
    end))

    table.insert(connections, UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
        if input == dragInput and dragging then
            didDrag = true
            local delta = input.Position - mousePos
            target.Position = UDim2.new(
                framePos.X.Scale, framePos.X.Offset + delta.X,
                framePos.Y.Scale, framePos.Y.Offset + delta.Y
            )
        end
    end))

    return function()
        for _, conn in ipairs(connections) do
            pcall(function() conn:Disconnect() end)
        end
        table.clear(connections)
    end, function()
        return dragging
    end, function()
        -- consumeDidDrag: returns true if user actually dragged, then resets
        local was = didDrag
        didDrag = false
        return was
    end
end

--- Get the predicted insertion LayoutOrder for re-docking.
--- Walks the column children sorted by LayoutOrder to find the slot where dropY falls.
local function GetInsertOrder(parentFrame, dropY)
    local children = {}
    for _, child in ipairs(parentFrame:GetChildren()) do
        if child:IsA("GuiObject") and child.Name ~= "Placeholder" and child.Name ~= "SectionSpacing" and child.Name ~= "_PinGhost_" then
            table.insert(children, child)
        end
    end
    table.sort(children, function(a, b) return a.LayoutOrder < b.LayoutOrder end)

    local insertOrder = (#children > 0) and (children[#children].LayoutOrder + 1) or 1
    for i, child in ipairs(children) do
        local midY = child.AbsolutePosition.Y + child.AbsoluteSize.Y / 2
        if dropY < midY then
            insertOrder = child.LayoutOrder
            break
        end
    end
    return insertOrder
end

--- Shift layout orders of children >= insertOrder up by 1 to make room.
local function ShiftLayoutOrders(parentFrame, insertOrder)
    for _, child in ipairs(parentFrame:GetChildren()) do
        if child:IsA("GuiObject") and child.Name ~= "_PinGhost_" and child.LayoutOrder >= insertOrder then
            child.LayoutOrder = child.LayoutOrder + 1
        end
    end
end

--- Check if a point (x, y) is within the main GUI scrolling frame.
local function IsOverMainElements(x, y)
    local elementsFrame = Elements
    if not elementsFrame then return false end
    -- Check the current visible tab page
    local currentPage = elementsFrame.UIPageLayout.CurrentPage
    if not currentPage then return false end
    local pos = currentPage.AbsolutePosition
    local sz = currentPage.AbsoluteSize
    return x >= pos.X and x <= pos.X + sz.X and y >= pos.Y and y <= pos.Y + sz.Y
end

--- Get the current visible TabPage.
local function GetCurrentTabPage()
    if Elements and Elements.UIPageLayout and Elements.UIPageLayout.CurrentPage then
        return Elements.UIPageLayout.CurrentPage
    end
    return nil
end

--- Dock a floating panel back into its original parent or current tab page.
local function DockPanel(element, dropY)
    local pd = _pinData[element]
    if not pd or pd.IsPinned then return end

    pd.IsPinned = true

    -- Disconnect drag & render & drag-end connections
    if pd.DragDisconnect then
        pd.DragDisconnect()
        pd.DragDisconnect = nil
    end
    if pd.RenderConnection then
        pcall(function() pd.RenderConnection:Disconnect() end)
        pd.RenderConnection = nil
    end
    if pd.DragEndConnection then
        pcall(function() pd.DragEndConnection:Disconnect() end)
        pd.DragEndConnection = nil
    end

    -- Determine target parent (original parent or current tab page)
    local targetParent = pd.OriginalParent
    if not targetParent or not targetParent.Parent then
        targetParent = GetCurrentTabPage() or pd.OriginalParent
    end

    -- Calculate insertion order
    local insertOrder
    if dropY then
        insertOrder = GetInsertOrder(targetParent, dropY)
    else
        insertOrder = pd.OriginalLayoutOrder or 1
    end

    -- Shift existing children to make room
    ShiftLayoutOrders(targetParent, insertOrder)

    -- Reparent
    element.LayoutOrder = insertOrder
    -- Don't parent to targetParent yet — we'll slide first, then reparent in the animation callback

    -- Update pin icon to "pinned" state
    if pd.PinButton then
        RayfieldLibrary:_ApplyIcon(pd.PinButton, "pin")
        pd.PinButton.ImageColor3 = Color3.fromRGB(180, 180, 180)
        -- For regular elements on desktop (not sections, not mobile), hide the pin button again (hover-reveal)
        local isSection = element:FindFirstChild('_UIPadding_') ~= nil
        if not isSection and not isMobile then
            pd.PinButton.BackgroundTransparency = 1
            pd.PinButton.ImageTransparency = 1
        end
    end

    -- If this is a section, restore PinButtons on child elements inside the Holder
    local holder = element:FindFirstChild("Holder")
    if holder then
        for _, desc in ipairs(holder:GetDescendants()) do
            if desc:IsA("ImageButton") and desc.Name == "PinButton" then
                desc.Visible = true
            end
        end
    end

    -- Remove floating stroke
    local floatStroke = element:FindFirstChild("_PinFloatStroke_")
    if floatStroke then
        floatStroke:Destroy()
    end

    -- Hide drop highlight
    DropHighlight.Visible = false

    -- Restore ZIndex on element and all descendants
    if pd.OriginalZIndices then
        element.ZIndex = pd.OriginalZIndices[element] or 1
        for _, desc in ipairs(element:GetDescendants()) do
            if desc:IsA("GuiObject") and pd.OriginalZIndices[desc] then
                desc.ZIndex = pd.OriginalZIndices[desc]
            end
        end
        pd.OriginalZIndices = nil
    end

    -- Animate: smooth slide from floating position back into the list
    local floatAbsPosDock = FloatingPanels.AbsolutePosition
    local curAbsPos = element.AbsolutePosition
    local floatingX = curAbsPos.X - floatAbsPosDock.X
    local floatingY = curAbsPos.Y - floatAbsPosDock.Y
    local currentW = element.AbsoluteSize.X
    local currentH = element.AbsoluteSize.Y

    -- Temporarily keep element in FloatingPanels for the slide animation
    element.Parent = FloatingPanels
    element.AnchorPoint = Vector2.new(0, 0)
    element.AutomaticSize = Enum.AutomaticSize.None
    element.Size = UDim2.new(0, currentW, 0, currentH)
    element.Position = UDim2.new(0, floatingX, 0, floatingY)

    -- Determine where the ghost placeholder is on screen
    local ghostTarget = pd.Ghost
    local ghostAbsPos = ghostTarget and ghostTarget.AbsolutePosition or targetParent.AbsolutePosition
    local slideTargetX = ghostAbsPos.X - floatAbsPosDock.X
    local slideTargetY = ghostAbsPos.Y - floatAbsPosDock.Y

    -- Get the target height
    local targetH = pd.OriginalSize.Y.Offset
    if targetH <= 0 then targetH = currentH end

    -- Slide + shrink to match the ghost spot
    local slideTween = TweenService:Create(element,
        TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, slideTargetX, 0, slideTargetY),
            Size = UDim2.new(pd.OriginalSize.X.Scale, pd.OriginalSize.X.Offset, 0, targetH),
        })
    slideTween:Play()
    slideTween.Completed:Connect(function()
        -- Now reparent into the actual list
        element.Parent = targetParent
        element.LayoutOrder = insertOrder
        element.Position = UDim2.new(0, 0, 0, 0)

        -- Re-enable auto size if element originally used it
        -- For sections (AutomaticSize elements), skip restoring the small original Size
        -- to avoid a collapse-then-expand flash. Instead, keep the current pixel size
        -- and let AutomaticSize take over seamlessly.
        if pd.HadAutoSize then
            -- Set pixel size to match current absolute size so there's no visual jump
            local absW = element.AbsoluteSize.X
            local absH = element.AbsoluteSize.Y
            element.Size = UDim2.new(pd.OriginalSize.X.Scale, pd.OriginalSize.X.Offset, 0, absH)
            element.AutomaticSize = pd.HadAutoSize
        else
            element.Size = pd.OriginalSize
        end

        -- Destroy ghost
        if pd.Ghost and pd.Ghost.Parent then
            pd.Ghost:Destroy()
            pd.Ghost = nil
        end
    end)
end

--- Unpin an element from its parent and float it on the overlay.
local function UnpinPanel(element)
    local pd = _pinData[element]
    if not pd or not pd.IsPinned then return end

    pd.IsPinned = false
    pd.OriginalParent = element.Parent
    pd.OriginalSize = element.Size
    pd.HadAutoSize = (element.AutomaticSize ~= Enum.AutomaticSize.None) and element.AutomaticSize or nil

    -- Assign unique sequential LayoutOrder to all siblings based on current visual order
    -- This ensures the ghost and re-docking position are correctly tracked
    local parent = element.Parent
    if parent then
        local siblings = {}
        for _, child in ipairs(parent:GetChildren()) do
            if child:IsA("GuiObject") and child.Name ~= "Placeholder" and child.Name ~= "SectionSpacing" and child.Name ~= "_PinGhost_" then
                table.insert(siblings, child)
            end
        end
        -- Sort by current LayoutOrder first, then by child index for ties
        table.sort(siblings, function(a, b)
            if a.LayoutOrder ~= b.LayoutOrder then
                return a.LayoutOrder < b.LayoutOrder
            end
            -- Same LayoutOrder: preserve instance (child) order
            for _, child in ipairs(parent:GetChildren()) do
                if child == a then return true end
                if child == b then return false end
            end
            return false
        end)
        for i, sibling in ipairs(siblings) do
            sibling.LayoutOrder = i
        end
    end

    pd.OriginalLayoutOrder = element.LayoutOrder

    -- Create ghost placeholder in original position
    local ghost = Instance.new("Frame")
    ghost.Name = "_PinGhost_"
    ghost.BackgroundTransparency = 0.85
    ghost.BackgroundColor3 = Color3.fromRGB(43, 105, 159)
    ghost.BorderSizePixel = 0
    local ghostHeight = math.max(36, element.AbsoluteSize.Y)
    ghost.Size = UDim2.new(element.Size.X.Scale, element.Size.X.Offset, 0, ghostHeight)
    ghost.LayoutOrder = element.LayoutOrder
    ghost.Parent = pd.OriginalParent
    ghost.Visible = true

    local ghostCorner = Instance.new("UICorner")
    ghostCorner.CornerRadius = UDim.new(0, 5)
    ghostCorner.Parent = ghost

    local ghostStroke = Instance.new("UIStroke")
    ghostStroke.Color = Color3.fromRGB(43, 105, 159)
    ghostStroke.Thickness = 1
    ghostStroke.Transparency = 0.5
    ghostStroke.Parent = ghost

    -- Resolve display name: use stored ElementName from _pinData, then try Title.Text, then element.Name
    local displayName = (pd.ElementName and pd.ElementName ~= "" and pd.ElementName)
        or (element:FindFirstChild("Title") and element.Title:IsA("TextLabel") and element.Title.Text)
        or element.Name or "Element"

    -- Inner holder to center icon + text as a group
    local ghostCenter = Instance.new("Frame")
    ghostCenter.Name = "GhostCenter"
    ghostCenter.BackgroundTransparency = 1
    ghostCenter.AnchorPoint = Vector2.new(0.5, 0.5)
    ghostCenter.Position = UDim2.new(0.5, 0, 0.5, 0)
    ghostCenter.AutomaticSize = Enum.AutomaticSize.X
    ghostCenter.Size = UDim2.new(0, 0, 1, 0)
    ghostCenter.Parent = ghost

    local ghostLayout = Instance.new("UIListLayout")
    ghostLayout.FillDirection = Enum.FillDirection.Horizontal
    ghostLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    ghostLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    ghostLayout.Padding = UDim.new(0, 5)
    ghostLayout.Parent = ghostCenter

    -- Ghost pin icon (Lucide)
    local ghostIcon = Instance.new("ImageLabel")
    ghostIcon.Name = "GhostIcon"
    ghostIcon.BackgroundTransparency = 1
    ghostIcon.Size = UDim2.new(0, 14, 0, 14)
    ghostIcon.ImageColor3 = Color3.fromRGB(43, 105, 159)
    ghostIcon.ImageTransparency = 0.4
    ghostIcon.LayoutOrder = 1
    ghostIcon.Parent = ghostCenter
    RayfieldLibrary:_ApplyIcon(ghostIcon, "pin")

    local ghostLabel = Instance.new("TextLabel")
    ghostLabel.Name = "GhostLabel"
    ghostLabel.BackgroundTransparency = 1
    ghostLabel.AutomaticSize = Enum.AutomaticSize.X
    ghostLabel.Size = UDim2.new(0, 0, 1, 0)
    ghostLabel.Font = Enum.Font.GothamMedium
    ghostLabel.Text = displayName
    ghostLabel.TextColor3 = Color3.fromRGB(43, 105, 159)
    ghostLabel.TextTransparency = 0.4
    ghostLabel.TextSize = 13
    ghostLabel.LayoutOrder = 2
    ghostLabel.Parent = ghostCenter

    pd.Ghost = ghost

    -- Calculate screen position before reparenting
    local absPos = element.AbsolutePosition
    local absSize = element.AbsoluteSize

    -- Disable automatic size and set fixed pixel size
    element.AutomaticSize = Enum.AutomaticSize.None
    element.Size = UDim2.new(0, absSize.X, 0, absSize.Y)

    -- Reparent to floating overlay
    element.Parent = FloatingPanels

    -- FIX: Subtract FloatingPanels' own AbsolutePosition to get correct local coords
    local floatAbsPos = FloatingPanels.AbsolutePosition
    local startX = absPos.X - floatAbsPos.X
    local startY = absPos.Y - floatAbsPos.Y

    -- Determine which side of Main has more space, and slide the element there
    local screenWidth = Camera.ViewportSize.X
    local mainAbsPos = Main.AbsolutePosition
    local mainAbsSize = Main.AbsoluteSize
    local spaceLeft = mainAbsPos.X
    local spaceRight = screenWidth - (mainAbsPos.X + mainAbsSize.X)
    local gap = 12 -- pixels between Main and the floating element

    local finalX
    if spaceRight >= absSize.X + gap then
        -- Enough room on the right
        finalX = (mainAbsPos.X + mainAbsSize.X + gap) - floatAbsPos.X
    elseif spaceLeft >= absSize.X + gap then
        -- Enough room on the left
        finalX = (mainAbsPos.X - absSize.X - gap) - floatAbsPos.X
    elseif spaceRight >= spaceLeft then
        -- More space on right, even if tight
        finalX = (mainAbsPos.X + mainAbsSize.X + gap) - floatAbsPos.X
    else
        -- More space on left
        finalX = (mainAbsPos.X - absSize.X - gap) - floatAbsPos.X
    end
    -- Clamp so it doesn't go off-screen
    finalX = math.max(0, math.min(finalX, screenWidth - absSize.X - floatAbsPos.X))

    -- Stack vertically: find existing floating panels on this side and offset below them
    local stackY = 0
    local stackGap = 8
    for otherElem, otherPd in pairs(_pinData) do
        if otherElem ~= element and not otherPd.IsPinned and otherElem.Parent == FloatingPanels then
            local otherPos = otherElem.AbsolutePosition
            local otherSize = otherElem.AbsoluteSize
            local otherLeft = otherPos.X - floatAbsPos.X
            local otherRight = otherLeft + otherSize.X
            -- Check if they overlap horizontally (same column)
            if finalX < otherRight and (finalX + absSize.X) > otherLeft then
                local otherBottom = (otherPos.Y - floatAbsPos.Y) + otherSize.Y + stackGap
                if otherBottom > stackY then
                    stackY = otherBottom
                end
            end
        end
    end
    local finalY = math.max(0, stackY > 0 and stackY or startY)

    -- Start slightly scaled down at original position for a pop-out effect
    element.AnchorPoint = Vector2.new(0.5, 0.5)
    local centerX = startX + absSize.X / 2
    local centerY = startY + absSize.Y / 2
    element.Position = UDim2.new(0, centerX, 0, centerY)
    element.Size = UDim2.new(0, absSize.X * 0.92, 0, absSize.Y * 0.92)

    -- Animate: scale up + slide to the side of Main
    local finalCenterX = finalX + absSize.X / 2
    local finalCenterY = finalY + absSize.Y / 2
    local popTween = TweenService:Create(element, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, absSize.X, 0, absSize.Y),
        Position = UDim2.new(0, finalCenterX, 0, finalCenterY),
    })
    popTween:Play()
    popTween.Completed:Connect(function()
        -- Reset anchor back to top-left for dragging consistency
        element.AnchorPoint = Vector2.new(0, 0)
        element.Position = UDim2.new(0, finalX, 0, finalY)
    end)

    -- FIX: Bump ZIndex uniformly on element AND all descendants so they render above Main
    -- IMPORTANT: use the same offset for parent and children to preserve relative order,
    -- otherwise the parent background can render on top of child text.
    local zOffset = 50
    local savedZ = {}
    savedZ[element] = element.ZIndex
    element.ZIndex = element.ZIndex + zOffset
    for _, desc in ipairs(element:GetDescendants()) do
        if desc:IsA("GuiObject") then
            savedZ[desc] = desc.ZIndex
            desc.ZIndex = desc.ZIndex + zOffset
        end
    end
    pd.OriginalZIndices = savedZ

    -- Add a subtle floating stroke to signal detached state (white, not fading text)
    local floatStroke = element:FindFirstChild("_PinFloatStroke_")
    if not floatStroke then
        floatStroke = Instance.new("UIStroke")
        floatStroke.Name = "_PinFloatStroke_"
        floatStroke.Color = Color3.fromRGB(255, 255, 255)
        floatStroke.Thickness = 1.5
        floatStroke.Transparency = 0.3
        floatStroke.Parent = element
    end

    -- Update pin icon to "unpinned" state
    if pd.PinButton then
        RayfieldLibrary:_ApplyIcon(pd.PinButton, "pin-off")
        pd.PinButton.ImageColor3 = Color3.fromRGB(255, 255, 255)
        -- Force pin button visible when floating (so user can re-dock)
        pd.PinButton.BackgroundTransparency = 0.6
        pd.PinButton.ImageTransparency = 0.3
    end

    -- If this is a section, hide PinButtons on child elements inside the Holder
    local holder = element:FindFirstChild("Holder")
    if holder then
        for _, desc in ipairs(holder:GetDescendants()) do
            if desc:IsA("ImageButton") and desc.Name == "PinButton" then
                desc.Visible = false
            end
        end
    end

    -- Make draggable
    local disconnectDrag, isDragging, consumeDidDrag = MakePinDraggable(element, element)
    pd.DragDisconnect = disconnectDrag

    -- FIX: Debounce flag — ignore auto-dock for a short time after unpinning
    -- This prevents the very next mouse-up (from the pin-button click itself)
    -- from immediately re-docking the element.
    local unpinReady = false
    task.delay(0.3, function()
        unpinReady = true
    end)

    -- RenderStepped loop: watch panel center position for drop-zone highlighting
    pd.RenderConnection = RunService.RenderStepped:Connect(function()
        if not pd or pd.IsPinned then return end

        local panelPos = element.AbsolutePosition
        local panelSize = element.AbsoluteSize
        local centerX = panelPos.X + panelSize.X / 2
        local centerY = panelPos.Y + panelSize.Y / 2

        if IsOverMainElements(centerX, centerY) and isDragging() then
            -- Show drop highlight only while actively dragging
            DropHighlight.Visible = true
            local currentPage = GetCurrentTabPage()
            if currentPage then
                local insertOrder = GetInsertOrder(currentPage, centerY)
                -- Find the Y position for the highlight line
                local hlY = currentPage.AbsolutePosition.Y
                local children = {}
                for _, child in ipairs(currentPage:GetChildren()) do
                    if child:IsA("GuiObject") and child.Name ~= "Placeholder" and child.Name ~= "SectionSpacing" and child.Name ~= "_PinGhost_" then
                        table.insert(children, child)
                    end
                end
                table.sort(children, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
                for _, child in ipairs(children) do
                    if child.LayoutOrder < insertOrder then
                        hlY = child.AbsolutePosition.Y + child.AbsoluteSize.Y + 2
                    end
                end
                DropHighlight.Position = UDim2.new(0, currentPage.AbsolutePosition.X + 5, 0, hlY)
                DropHighlight.Size = UDim2.new(0, currentPage.AbsoluteSize.X - 10, 0, 3)
            end
            TweenService:Create(DropHighlight, TweenInfo.new(0.15), { BackgroundTransparency = 0.3 }):Play()
        else
            TweenService:Create(DropHighlight, TweenInfo.new(0.15), { BackgroundTransparency = 1 }):Play()
        end
    end)

    -- Auto-dock on drag release over main elements
    -- FIX: Only dock when user was ACTUALLY DRAGGING (not just any mouse click),
    -- and only after the debounce period has passed.
    local dragEndConn
    dragEndConn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if not pd.IsPinned and unpinReady then
                -- Only auto-dock if the user actually moved/dragged the element
                if not consumeDidDrag() then return end
                task.defer(function()
                    if pd.IsPinned then return end
                    local panelPos = element.AbsolutePosition
                    local panelSize = element.AbsoluteSize
                    local centerX = panelPos.X + panelSize.X / 2
                    local centerY = panelPos.Y + panelSize.Y / 2
                    if IsOverMainElements(centerX, centerY) then
                        DockPanel(element, centerY)
                    end
                end)
            elseif pd.IsPinned then
                pcall(function() dragEndConn:Disconnect() end)
                pd.DragEndConnection = nil
            end
        end
    end)
    pd.DragEndConnection = dragEndConn
end

--- Creates a small pin icon button on the top-right corner of an element.
--- When clicked, toggles pin/unpin state.
--- @param parentElement Frame -- The element frame (Button, Toggle, Slider, Section, etc.)
--- @param elementName string -- Display name for the ghost placeholder
local function CreatePinButton(parentElement, elementName)
    if not parentElement then return end

    -- Initialize pin data
    _pinData[parentElement] = {
        IsPinned = true,
        ElementName = elementName,
        OriginalParent = parentElement.Parent,
        OriginalLayoutOrder = parentElement.LayoutOrder,
        OriginalSize = parentElement.Size,
        Ghost = nil,
        DragDisconnect = nil,
        RenderConnection = nil,
        PinButton = nil,
    }

    -- Determine if this is a section (has _UIPadding_) or a regular element
    local isSection = parentElement:FindFirstChild('_UIPadding_') ~= nil

    -- Create the pin icon button
    local PinBtn = Instance.new("ImageButton")
    PinBtn.Name = "PinButton"
    PinBtn.Parent = parentElement
    PinBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    PinBtn.AnchorPoint = Vector2.new(1, 0)
    PinBtn.ZIndex = 55
    PinBtn.BorderSizePixel = 0
    PinBtn.ImageColor3 = Color3.fromRGB(180, 180, 180)

    if isSection then
        PinBtn.Size = UDim2.new(0, 16, 0, 16)
        PinBtn.Position = UDim2.new(1, -4, 0, 4)
    else
        PinBtn.Size = UDim2.new(0, 12, 0, 12)
        PinBtn.Position = UDim2.new(1, -2, 0, 2)
    end
    PinBtn.AutoButtonColor = false

    if isSection or isMobile then
        -- Sections and mobile: always visible, subtle
        PinBtn.BackgroundTransparency = 0.6
        PinBtn.ImageTransparency = 0.3
    else
        -- Regular elements on desktop: hidden by default, revealed on hover
        PinBtn.BackgroundTransparency = 1
        PinBtn.ImageTransparency = 1
    end

    -- Apply Lucide "pin" icon
    RayfieldLibrary:_ApplyIcon(PinBtn, "pin")

    local pinCorner = Instance.new("UICorner")
    pinCorner.CornerRadius = UDim.new(0, 4)
    pinCorner.Parent = PinBtn

    _pinData[parentElement].PinButton = PinBtn

    -- For regular elements on desktop: show/hide pin on element hover
    if not isSection and not isMobile then
        local elementHovered = false
        local pinHovered = false

        local function showPin()
            TweenService:Create(PinBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
                BackgroundTransparency = 0.6,
                ImageTransparency = 0.3
            }):Play()
        end

        local function hidePin()
            -- Don't hide if element is unpinned (floating) — keep it visible for re-docking
            local pd = _pinData[parentElement]
            if pd and not pd.IsPinned then return end
            TweenService:Create(PinBtn, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
                BackgroundTransparency = 1,
                ImageTransparency = 1
            }):Play()
        end

        parentElement.MouseEnter:Connect(function()
            elementHovered = true
            showPin()
        end)
        parentElement.MouseLeave:Connect(function()
            elementHovered = false
            task.delay(0.1, function()
                if not elementHovered and not pinHovered then
                    hidePin()
                end
            end)
        end)
        PinBtn.MouseEnter:Connect(function()
            pinHovered = true
            -- Highlight effect on direct pin hover
            TweenService:Create(PinBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
                BackgroundTransparency = 0.2,
                ImageTransparency = 0,
                ImageColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
        end)
        PinBtn.MouseLeave:Connect(function()
            pinHovered = false
            local pd = _pinData[parentElement]
            local color = (pd and not pd.IsPinned) and Color3.fromRGB(255, 150, 50) or Color3.fromRGB(180, 180, 180)
            if elementHovered then
                -- Still hovering element, show pin in normal state
                TweenService:Create(PinBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
                    BackgroundTransparency = 0.6,
                    ImageTransparency = 0.3,
                    ImageColor3 = color
                }):Play()
            else
                task.delay(0.1, function()
                    if not elementHovered and not pinHovered then
                        hidePin()
                    end
                end)
            end
        end)
    else
        -- Section / mobile elements: always visible, hover effects on desktop, tap feedback on mobile
        PinBtn.MouseEnter:Connect(function()
            TweenService:Create(PinBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
                BackgroundTransparency = 0.2,
                ImageTransparency = 0,
                ImageColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
        end)
        PinBtn.MouseLeave:Connect(function()
            local pd = _pinData[parentElement]
            local color = (pd and not pd.IsPinned) and Color3.fromRGB(255, 150, 50) or Color3.fromRGB(180, 180, 180)
            TweenService:Create(PinBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
                BackgroundTransparency = 0.6,
                ImageTransparency = 0.3,
                ImageColor3 = color
            }):Play()
        end)
    end

    -- Click/tap: toggle pin/unpin with visual feedback
    PinBtn.MouseButton1Click:Connect(function()
        -- Brief tap flash feedback (works on both mobile and desktop)
        TweenService:Create(PinBtn, TweenInfo.new(0.1, Enum.EasingStyle.Quint), {
            BackgroundTransparency = 0,
            ImageTransparency = 0,
            ImageColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
        task.delay(0.15, function()
            local pd = _pinData[parentElement]
            if pd then
                local color = (not pd.IsPinned) and Color3.fromRGB(255, 150, 50) or Color3.fromRGB(180, 180, 180)
                TweenService:Create(PinBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {
                    BackgroundTransparency = 0.6,
                    ImageTransparency = 0.3,
                    ImageColor3 = color
                }):Play()
            end
        end)

        local pd = _pinData[parentElement]
        if not pd then return end
        if pd.IsPinned then
            UnpinPanel(parentElement)
        else
            DockPanel(parentElement, nil)
        end
    end)

    return PinBtn
end

