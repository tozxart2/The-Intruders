                else
                    Dropdown.Selected.Text = DropdownSettings.CurrentOption[1]
                end
            end

            Refresh()

            -- Fire initial callback so consumers get the properly typed value
            -- (fixes old saved data where single-select was stored as table)
            -- Some consumers can opt out to avoid startup write-back overrides.
            if DropdownSettings.Callback and not DropdownSettings.SkipInitialCallback then
